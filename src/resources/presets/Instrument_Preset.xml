<?xml version="1.0" encoding="utf-8"?>
<preset name="ModernInstrument">
  <meta>
    <description>Instrument-focused configuration with CLAP/AUv3 targets and GPU-friendly options.</description>
  </meta>
  <project_info>
    <template_name>Instrument Plugin</template_name>
    <template_url>https://github.com/SeamusMullan/PluginTemplate.git</template_url>
    <project_name>ModernInstrument</project_name>
    <product_name>Modern Instrument</product_name>
    <version>1.1.0</version>
    <company_name>DirektDSP</company_name>
    <bundle_id>com.direkt.instrument</bundle_id>
    <manufacturer_code>DkIN</manufacturer_code>
    <plugin_code>DKIN</plugin_code>
    <output_directory>~/AudioPlugins/ModernInstrument</output_directory>
  </project_info>
  <configuration>
    <standalone>true</standalone>
    <vst3>true</vst3>
    <au>true</au>
    <auv3>true</auv3>
    <clap>true</clap>
    <gui_width>1280</gui_width>
    <gui_height>720</gui_height>
    <resizable>true</resizable>
    <background_image></background_image>
    <code_signing>false</code_signing>
    <installer>false</installer>
    <default_bypass>false</default_bypass>
    <input_gain>false</input_gain>
    <output_gain>true</output_gain>
  </configuration>
  <implementations>
    <moonbase_licensing>true</moonbase_licensing>
    <melatonin_inspector>true</melatonin_inspector>
    <custom_gui_framework>true</custom_gui_framework>
    <logging_framework>true</logging_framework>
    <clap_builds>true</clap_builds>
    <preset_management>true</preset_management>
    <preset_format>Binary</preset_format>
    <ab_comparison>true</ab_comparison>
    <state_management>true</state_management>
    <gpu_audio>true</gpu_audio>
  </implementations>
  <user_experience>
    <wizard>true</wizard>
    <preview>true</preview>
    <preset_management>true</preset_management>
  </user_experience>
  <development_workflow>
    <vcs>true</vcs>
    <testing>true</testing>
    <code_quality>true</code_quality>
    <validation_tools>true</validation_tools>
    <scaffolding>true</scaffolding>
  </development_workflow>
</preset>
